---
const { tags, compact = false } = Astro.props;
---
<p class:list={['tags', { compact }]} aria-label="Technologies">
	{tags.map((tag) => (
		<span class="tag">{tag}</span>
	))}
</p>

<style>
	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.55rem;
		margin-top: 1rem;
	}

	.tags.compact {
		margin-top: 0;
	}

	.tag {
		padding: 0.35rem 0.7rem;
		border: 1px solid var(--color-line);
		border-radius: 999px;
		background: color-mix(in srgb, var(--color-accent-soft) 45%, white 55%);
		font-family: var(--font-sans);
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0.03em;
		color: var(--color-text-soft);
	}
</style>
