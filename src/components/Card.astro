---
import Tags from './Tags.astro';
const { title, url, link, description, date, tags } = Astro.props;
---

<a href={link} class="link" data-track-card="{title}" data-card-type={date ? 'blog' : 'project'}>
  <article class="card">
    <div class="header">
      <h3 class="title">
        {title}
      </h3>
      <p class="subheader">
        {date ?
          new Date(date).toLocaleDateString("en-us", {
            year: "numeric",
            month: "short",
            day: "numeric",
          })
        :
          <a href={url} class="link" target="_blank" rel="noreferrer" title={title}>
            {url}
          </a>
          <span class="material-symbols-outlined">open_in_new</span>
        }
      </p>
    </div>
    <p class="description">
      {description}...<span class="readon">read more &rarr;</span>
    </p>
  <script>
    document.addEventListener('astro:page-load', () => {
      const w = window as any;
      // Track card title clicks
      document.querySelectorAll('[data-track-card]').forEach(link => {
        link.addEventListener('click', (e) => {
          const title = (e.currentTarget as HTMLElement).getAttribute('data-track-card');
          const type = (e.currentTarget as HTMLElement).getAttribute('data-card-type');
          if (typeof w.gtag !== 'undefined') {
            w.gtag('event', 'card_click', {
              content_type: type,
              item_id: title,
              link_url: (e.currentTarget as HTMLAnchorElement).href
            });
          }
        });
      });
      
      // Track "read more" clicks
      document.querySelectorAll('[data-track-readmore]').forEach(link => {
        link.addEventListener('click', (e) => {
          const title = (e.currentTarget as HTMLElement).getAttribute('data-track-readmore');
          const type = (e.currentTarget as HTMLElement).getAttribute('data-card-type');
          if (typeof w.gtag !== 'undefined') {
            w.gtag('event', 'read_more_click', {
              content_type: type,
              item_id: title,
              link_url: (e.currentTarget as HTMLAnchorElement).href
            });
          }
        });
      });
    });
  </script>
    {tags?.length ? <Tags tags={tags} /> : null}
  </article>
</a>


<style>
  .card {
    display: grid;
    grid-template-rows: auto 1fr auto;
    padding: 1rem;
    background: var(--background-contrast-color);
    transition: all .25s;
    position: relative;
    border-radius: 6px;
    bottom: 0;
  }
  .card::before {
    content: "";
    border-radius: 0 0 0 6px;
    position: absolute;
    right: 0;
    border-style: solid;
    border-width: 20px;
    border-bottom-color: var(--theme-color-2a);
    border-top-color: var(--theme-color-1);
    border-left-color: var(--theme-color-2a);
    border-right-color: var(--theme-color-1);
  }
  .card:hover {
    bottom: 6px;
  }
  .header {
    margin-bottom: 1rem;
    padding-bottom: .5rem;
    border-bottom: 5px solid var(--background-color);
  }
  .title {
    display: flex;
    flex-direction: column;
    width: calc(100% - 30px);
  }
  .subheader {
    margin-top: .5rem;
    font-weight: normal;
    font-size: 12px;
    font-style: italic;
    white-space: nowrap;
    display: flex;
    align-items: center;
    gap: .25rem;
  }
  .material-symbols-outlined {
    font-family: 'Material Symbols Outlined';
    font-size: 1rem;
  }
  .link {
    text-decoration: none;
    display: flex;
  }
  .description {
    flex: 1 1 100%;
    font-size: 1rem;
  }
  .readon {
    display: block;
    font-weight: bold;
    white-space: nowrap;
  }
</style>