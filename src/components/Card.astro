---
import Tags from './Tags.astro';
const { title, url, link, description, date, tags } = Astro.props;
const isBlog = Boolean(date);
---

<a href={link} class="card-link" data-track-card={title} data-card-type={isBlog ? 'blog' : 'project'}>
	<article class="card">
		<div class="card-top">
			<p class="card-meta">
				{isBlog ? (
					<time datetime={new Date(date).toISOString()}>
						{new Date(date).toLocaleDateString('en-us', {
							year: 'numeric',
							month: 'long',
							day: 'numeric',
						})}
					</time>
				) : (
					<>
						<span>Project</span>
						{url && <span class="project-url">{url.replace(/^https?:\/\//, '').replace(/\/$/, '')}</span>}
					</>
				)}
			</p>
			<h3 class="card-title">{title}</h3>
		</div>
		<p class="card-description">
			{description}...
		</p>
		<div class="card-bottom">
			<p class="card-cta">{isBlog ? 'Read entry' : 'View case study'} <span aria-hidden="true">&rarr;</span></p>
			{tags?.length ? <Tags tags={tags} /> : null}
		</div>
	</article>
</a>

<script>
	document.addEventListener('astro:page-load', () => {
		const w = window as any;
		document.querySelectorAll('[data-track-card]').forEach((link) => {
			link.addEventListener('click', (e) => {
				const title = (e.currentTarget as HTMLElement).getAttribute('data-track-card');
				const type = (e.currentTarget as HTMLElement).getAttribute('data-card-type');
				if (typeof w.gtag !== 'undefined') {
					w.gtag('event', 'card_click', {
						content_type: type,
						item_id: title,
						link_url: (e.currentTarget as HTMLAnchorElement).href
					});
				}
			});
		});
	});
</script>

<style>
	.card-link {
		display: flex;
		text-decoration: none;
		color: inherit;
	}

	.card {
		display: grid;
		grid-template-rows: auto 1fr auto;
		gap: 1rem;
		width: 100%;
		padding: 1.35rem;
		border: 1px solid var(--color-line);
		border-radius: var(--radius-md);
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.72), rgba(255, 255, 255, 0.35)),
			var(--color-panel);
		box-shadow: 0 12px 30px rgba(35, 50, 42, 0.05);
		transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
	}

	.card-link:hover .card,
	.card-link:focus-visible .card {
		transform: translateY(-4px);
		box-shadow: 0 18px 34px rgba(35, 50, 42, 0.1);
		border-color: var(--color-line-strong);
	}

	.card-top,
	.card-bottom {
		display: grid;
		gap: 0.75rem;
	}

	.card-meta {
		display: flex;
		flex-wrap: wrap;
		gap: 0.55rem;
		font-family: var(--font-sans);
		font-size: 0.8rem;
		font-weight: 700;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: var(--color-text-soft);
	}

	.project-url {
		text-transform: none;
		letter-spacing: 0;
	}

	.card-title {
		max-width: 15ch;
	}

	.card-description {
		font-size: 1rem;
		line-height: 1.65;
		color: var(--color-text-soft);
	}

	.card-cta {
		font-family: var(--font-sans);
		font-size: 0.92rem;
		font-weight: 700;
		color: var(--color-accent);
	}
</style>
