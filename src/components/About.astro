---
import { Image } from 'astro:assets';
import face from '../assets/images/portrait.png';

const { featuredProjects = [], recentPosts = [], totalPosts = recentPosts.length } = Astro.props;
---

<section class="home-intro">
	<div class="intro-copy">
		<div class="intro-heading">
			<div>
				<p class="eyebrow">Ahoy</p>
				<h2>A thoughtful corner of the internet for work, writing, and rebuilding a life with care.</h2>
			</div>
			<Image src={face} alt="Portrait illustration of Wylie Fisher" width={220} class="portrait" />
		</div>
		<p>
			I'm Wylie: a dad, partner, longtime front-end developer, and systems-minded generalist who cares
			about clarity, accessibility, useful tools, and the everyday creativity found in gardens,
			campfires, books, and making things by hand.
		</p>
		<p>
			These days I’m focused on home, family, small web projects, and figuring out what an honest next
			chapter looks like. This site is my home base for that work.
		</p>
		<div class="intro-links">
			<a href="/projects/" class="primary-link">See projects</a>
			<a href="/blog/" class="secondary-link">Read the blog</a>
		</div>
	</div>
</section>

<section class="home-section">
	<div class="section-heading">
		<p class="eyebrow">A little more about me</p>
		<h2>Human first, builder second.</h2>
	</div>
	<div class="two-column-copy">
		<div class="copy-card">
			<p>
				I love Lego, books,
				animals, and the kind of creativity that shows up in kitchens, workshops, and backyards. Our
				home is shared with two cats, a dog named Meatball, and a few other tiny lives, with chickens
				still high on the wish list.
			</p>
			<p>
				I still think like a front-end developer even when the work extends beyond code. I care about
				structure, clear communication, documentation, fairness, and systems that make life easier for
				the people using them.
			</p>
		</div>
		<div class="copy-card">
			<p>
				Sometimes that shows up in software, sometimes in operations work, and sometimes in writing
				through a season of transition. I like things that are practical, handcrafted, and just a little
				unexpected.
			</p>
			<p>
				If you're curious about what I’m building, reading, or thinking through, you’ll find it here.
				The footer is the best place to find me elsewhere or say hello.
			</p>
		</div>
	</div>
</section>

<section class="home-section">
	<div class="section-heading section-heading-inline">
		<div>
			<p class="eyebrow">What I’m working on</p>
			<h2>Recent projects and ongoing tinkering.</h2>
		</div>
		<a href="/projects/" class="section-link">Browse all projects</a>
	</div>
	<div class="feature-grid">
		{featuredProjects.map((project) => (
			<a href={`/projects/${project.slug}/`} class="feature-card">
				<p class="feature-meta">{project.data.tags.join(' · ')}</p>
				<h3>{project.data.title}</h3>
				<p>{project.data.snippet}</p>
			</a>
		))}
	</div>
</section>

<section class="home-section">
	<div class="section-heading section-heading-inline">
		<div>
			<p class="eyebrow">Recent writing</p>
			<h2>Weekly notes, questions, and ordinary life.</h2>
		</div>
		<a href="/blog/" class="section-link">Visit the blog</a>
	</div>
	<div class="writing-list">
		{recentPosts.map((post, index) => {
			const postNumber = totalPosts - index;

			return (
				<a href={`/blog/${post.slug}/`} class="writing-item">
					<h3>#{postNumber}</h3>
					<time datetime={post.data.pubDate.toISOString()}>
						{post.data.pubDate.toLocaleDateString('en-us', {
							year: 'numeric',
							month: 'long',
							day: 'numeric',
						})}
					</time>
				</a>
			);
		})}
	</div>
</section>

<style>
	.home-intro {
		display: block;
	}

	.intro-copy,
	.copy-card,
	.feature-card,
	.writing-item {
		border: 1px solid var(--color-line);
		border-radius: var(--radius-md);
		background: color-mix(in srgb, var(--color-panel) 88%, white 12%);
	}

	.intro-copy {
		padding: clamp(1.5rem, 4vw, 2.5rem);
		display: grid;
		gap: 1rem;
	}

	.intro-heading {
		display: flex;
		gap: 1.25rem;
		align-items: center;
	}

	.intro-heading > div:first-child {
		display: grid;
		gap: 0.45rem;
	}

	.intro-links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
	}

	.primary-link,
	.secondary-link,
	.section-link {
		display: inline-flex;
		align-items: center;
		width: fit-content;
		padding: 0.7rem 1rem;
		border-radius: 999px;
		font-family: var(--font-sans);
		font-size: 0.92rem;
		font-weight: 700;
		text-decoration: none;
	}

	.primary-link {
		background: var(--color-text);
		color: var(--color-panel);
	}

	.primary-link:hover {
		color: var(--color-panel);
		background: var(--color-accent);
	}

	.secondary-link,
	.section-link {
		border: 1px solid var(--color-line);
		color: var(--color-text);
	}

	.portrait {
		float: right;
		width: 7rem;
		height: auto;
		margin: 0 0 0.75rem 1rem;
		object-fit: contain;
		aspect-ratio: 590 / 835;
	}

	.section-heading {
		display: grid;
		gap: 0.45rem;
	}

	.section-heading-inline {
		gap: 1rem;
	}

	.two-column-copy,
	.feature-grid,
	.writing-list {
		display: grid;
		gap: 1rem;
	}

	.copy-card,
	.feature-card,
	.writing-item {
		padding: 1.25rem;
		text-decoration: none;
		color: inherit;
	}

	.copy-card p + p,
	.feature-card p + p {
		margin-top: 0.85rem;
	}

	.feature-card:hover,
	.writing-item:hover {
		border-color: var(--color-line-strong);
	}

	.feature-meta {
		font-family: var(--font-sans);
		font-size: 0.8rem;
		font-weight: 700;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		color: var(--color-text-soft);
	}

	.feature-card h3 {
		margin-top: 0.5rem;
	}

	.writing-item h3 {
		font-size: clamp(1.5rem, 3vw, 2rem);
	}

	.writing-item {
		display: flex;
		flex-wrap: wrap;
		justify-content: space-between;
		gap: 1rem;
		align-items: end;
	}

	.writing-item time {
		font-family: var(--font-sans);
		font-size: 0.92rem;
		font-weight: 700;
		color: var(--color-text-soft);
	}

	@media (min-width: 860px) {
		.section-heading-inline,
		.two-column-copy,
		.feature-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}

		.section-heading-inline > .section-link {
			justify-self: end;
			align-self: end;
		}

		.intro-heading {
			display: grid;
			grid-template-columns: minmax(0, 1fr) auto;
			gap: 2rem;
		}

		.portrait {
			float: none;
			margin: 0;
		}
	}

	@media (max-width: 560px) {
		.portrait {
			margin: 0;
		}
	}
</style>
