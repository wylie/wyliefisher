---
const currentPath = Astro.url.pathname;
import Favicon from '../components/Favicon.astro';
import ShareImage from '../assets/images/share-image.png'
const { pageTitle } = Astro.props;
---
{currentPath === '/' && (
  <title>Wylie Fisher</title>
)}
{currentPath.startsWith('/projects/') && (
  <title>Wylie Fisher / Projects{pageTitle ? ` / ${pageTitle}` : ''}</title>
)}
{currentPath.startsWith('/blog/') && (
  <title>Wylie Fisher / Blog{pageTitle ? ` / ${pageTitle}` : ''}</title>
)}
{currentPath.startsWith('/resume/') && (
  <title>Wylie Fisher / Resume</title>
)}
<meta charset="utf-8" />
<meta name="description" content="Ahoy! I'm Wylie Fisher, a dad, developer, and outdoor enthusiast.">
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta property="og:type" content="website" />
<meta property="og:title" content="Wylie Fisher" />
<meta property="og:image" content={ShareImage.src} />
<meta property="og:image:alt" content="A drawing of Wylie under the name Wylie Fisher" />
<meta property="og:description" content="Ahoy! I'm Wylie Fisher, a dad, developer, and outdoor enthusiast." />
<meta property="og:locale" content="en_US" />
<meta property="og:site_name" content="Wylie Fisher" />
<script async src="https://www.googletagmanager.com/gtag/js?id=G-5X60SSE4MN"></script>
<script>
  (window as any).dataLayer = (window as any).dataLayer || [];
  function gtag(...args: any[]) { (window as any).dataLayer.push(args); }
  gtag('js', new Date());
  gtag('config', 'G-5X60SSE4MN', {
    send_page_view: false // We'll handle page views manually for view transitions
  });
  
  // Send initial page view
  gtag('event', 'page_view', {
    page_title: document.title,
    page_location: window.location.href,
    page_path: window.location.pathname
  });
  
  // Track page views on view transitions
  document.addEventListener('astro:page-load', () => {
    gtag('event', 'page_view', {
      page_title: document.title,
      page_location: window.location.href,
      page_path: window.location.pathname
    });
  });
</script>
<link rel="sitemap" href="/sitemap-index.xml" />
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0&icon_names=description,download,open_in_new" />
<Favicon />