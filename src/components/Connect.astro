---
import { Image } from 'astro:assets';
const { title, url, icon, label, description } = Astro.props;
import emailIcon from '../assets/images/email.png';
import githubIcon from '../assets/images/github.png';
import goodreadsIcon from '../assets/images/goodreads.png';
import linkedinIcon from '../assets/images/linkedin.png';
import dogearedIcon from '../assets/images/dogeared.png';

let iconSrc;
switch (icon) {
	case 'email':
		iconSrc = emailIcon;
		break;
	case 'github':
		iconSrc = githubIcon;
		break;
	case 'goodreads':
		iconSrc = goodreadsIcon;
		break;
	case 'dogeared':
		iconSrc = dogearedIcon;
		break;
	case 'linkedin':
		iconSrc = linkedinIcon;
		break;
}
---

<a
	class="connect-link"
	href={url}
	target={url.startsWith('http') ? '_blank' : undefined}
	rel={url.startsWith('http') ? 'noopener noreferrer' : undefined}
	title={title}
	data-track-social={icon}
>
	<span class="icon-wrap">
		<Image src={iconSrc} class="icon" alt="" />
	</span>
	<span class="link-copy">
		<span class="label">{label}</span>
		<span class="description">{description}</span>
	</span>
</a>

<style>
	.connect-link {
		display: flex;
		align-items: center;
		gap: 0.7rem;
		min-width: 0;
		padding: 0.8rem 0.9rem;
		border: 1px solid var(--color-line);
		border-radius: var(--radius-sm);
		background: color-mix(in srgb, var(--color-panel) 88%, white 12%);
		font-family: var(--font-sans);
		text-decoration: none;
		color: var(--color-text);
	}

	.connect-link:hover {
		border-color: var(--color-line-strong);
		background: var(--color-accent-soft);
		color: var(--color-warm);
	}

	.link-copy {
		display: grid;
		gap: 0.1rem;
	}

	.label {
		font-size: 0.95rem;
		font-weight: 700;
	}

	.description {
		font-family: var(--font-serif);
		font-size: 0.9rem;
		color: var(--color-text-soft);
	}

	.icon-wrap {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 1.6rem;
		height: 1.6rem;
	}

	.icon {
		width: 1.4rem;
		height: 1.4rem;
		filter: brightness(70%) saturate(70%) sepia(15%) hue-rotate(45deg);
	}
</style>
