---
import Connect from '../components/Connect.astro';
import clones from '../assets/data/clones.js';

const quotes = clones.clonesList;
---
<footer class="site-footer">
	<div class="footer-intro">
		<p class="eyebrow">Keep in touch</p>
		<h2>Thanks for stopping by.</h2>
		<p>Email is best for a real conversation. You can also find my code, work history, and reading life in the places below.</p>
	</div>
	<div class="footer-grid">
		<nav class="connect" aria-label="External links">
			<Connect url="mailto:wylie@wyliefisher.com" title="Email Wylie" icon="email" label="Email" description="Say hello" />
			<Connect url="https://github.com/wylie" title="Wylie on GitHub" icon="github" label="GitHub" description="Projects and code" />
			<Connect url="https://www.linkedin.com/in/wyliefisher/" title="Wylie on LinkedIn" icon="linkedin" label="LinkedIn" description="Work and experience" />
			<Connect url="https://www.goodreads.com/wyliefisher" title="Wylie on Goodreads" icon="goodreads" label="Goodreads" description="Books and reading" />
		</nav>
		<section class="footer-meta">
			<p>&copy; 2026 Wylie Fisher. Some independent work is done through Argon Collaborative LLC.</p>
			<p class="quote" id="footer-quote"></p>
		</section>
	</div>

	<script define:vars={{ quotes }}>
		function setRandomQuote() {
			const el = document.getElementById('footer-quote');
			if (el && Array.isArray(quotes) && quotes.length) {
				const randomIndex = Math.floor(Math.random() * quotes.length);
				el.textContent = quotes[randomIndex];
			}
		}

		setRandomQuote();
		document.addEventListener('astro:page-load', setRandomQuote);
	</script>
	<script>
		function trackSocialLinks() {
			document.querySelectorAll('[data-track-social]').forEach((link) => {
				if ((link as HTMLElement).dataset.trackingBound) return;

				link.addEventListener('click', (event) => {
					const target = event.currentTarget as HTMLAnchorElement;
					const w = window as any;
					if (typeof w.gtag !== 'undefined') {
						w.gtag('event', 'social_click', {
							platform: target.dataset.trackSocial,
							link_url: target.href
						});
					}
				});

				(link as HTMLElement).dataset.trackingBound = 'true';
			});
		}

		document.addEventListener('astro:page-load', trackSocialLinks);
		trackSocialLinks();
	</script>
</footer>

<style>
	.site-footer {
		margin-top: 4rem;
		padding-top: 2rem;
		border-top: 1px solid var(--color-line);
	}

	.footer-intro {
		display: grid;
		gap: 0.55rem;
		max-width: 42rem;
	}

	.footer-intro p:last-child {
		font-size: 1rem;
		color: var(--color-text-soft);
	}

	.footer-grid {
		display: grid;
		gap: 2rem;
		margin-top: 1.5rem;
		padding-top: 1.25rem;
		border-top: 1px dashed var(--color-line);
	}

	.connect {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.75rem;
	}

	.footer-meta {
		display: grid;
		gap: 0.65rem;
		align-content: center;
	}

	.footer-meta p {
		font-size: 1rem;
		color: var(--color-text-soft);
	}

	.quote {
		font-style: italic;
	}

	@media (max-width: 520px) {
		.connect {
			grid-template-columns: 1fr;
		}

		.footer-meta {
			padding-top: 0.25rem;
		}
	}

	@media (min-width: 800px) {
		.footer-grid {
			grid-template-columns: minmax(0, 1.5fr) minmax(15rem, 0.7fr);
			align-items: stretch;
		}

		.footer-meta {
			text-align: right;
		}
	}
</style>
