---
import Card from './Card.astro';
const {
	posts,
	placeFirstCardRight = false,
	useNumberTitles = false,
} = Astro.props;

const indexedPosts = posts.map((post, idx) => ({ post, originalIndex: idx }));

const getBlogPreview = (content = '', maxLength = 220) => {
	const plainText = content
		.replace(/```[\s\S]*?```/g, ' ')
		.replace(/`([^`]*)`/g, '$1')
		.replace(/!\[[^\]]*\]\([^)]*\)/g, ' ')
		.replace(/\[([^\]]+)\]\([^)]*\)/g, '$1')
		.replace(/<[^>]*>/g, ' ')
		.replace(/&nbsp;/g, ' ')
		.replace(/&amp;/g, '&')
		.replace(/&quot;/g, '"')
		.replace(/&#39;/g, "'")
		.replace(/&lt;/g, '<')
		.replace(/&gt;/g, '>')
		.replace(/[#>*_~]/g, ' ')
		.replace(/\s+/g, ' ')
		.trim();

	return plainText.slice(0, maxLength).trim();
};
---
<section class="listing-grid">
	<div class:list={['grid', { 'swap-columns': placeFirstCardRight }]}>
		{await Promise.all(indexedPosts.map(async ({ post, originalIndex }) => {
			const number = posts.length - originalIndex;
			const title = useNumberTitles ? `#${number}` : post.data.title;
			const description = post.data.pubDate
				? getBlogPreview(post.body, 220)
				: post.data.snippet;
			const tags = post.data.pubDate ? undefined : post.data.tags;

			return (
				<Card
					title={title}
					description={description}
					tags={tags}
					url={post.data.url}
					link={`${post.slug}/`}
					date={post.data.pubDate}
				/>
			);
		}))}
	</div>
</section>

<style>
	.listing-grid {
		gap: 1.5rem;
	}

	.grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1rem;
	}

	@media (min-width: 720px) {
		.grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
			gap: 1.25rem;
		}

		.grid.swap-columns > :nth-child(odd) {
			grid-column: 2;
		}

		.grid.swap-columns > :nth-child(even) {
			grid-column: 1;
		}
	}
</style>
