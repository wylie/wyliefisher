---
import Card from './Card.astro';
const { posts } = Astro.props;

const getBlogPreview = (content = '', maxLength = 200) => {
  const plainText = content
    .replace(/```[\s\S]*?```/g, ' ')
    .replace(/`([^`]*)`/g, '$1')
    .replace(/!\[[^\]]*\]\([^)]*\)/g, ' ')
    .replace(/\[([^\]]+)\]\([^)]*\)/g, '$1')
    .replace(/<[^>]*>/g, ' ')
    .replace(/&nbsp;/g, ' ')
    .replace(/&amp;/g, '&')
    .replace(/&quot;/g, '"')
    .replace(/&#39;/g, "'")
    .replace(/&lt;/g, '<')
    .replace(/&gt;/g, '>')
    .replace(/[#>*_~]/g, ' ')
    .replace(/\s+/g, ' ')
    .trim();

  return plainText.slice(0, maxLength).trim();
};
---
<section>
  <div class="grid">
    {await Promise.all(posts.map(async (post, idx) => {
      // Numbering: most recent is highest number
      const number = posts.length - idx;
      const description = post.data.pubDate
        ? getBlogPreview(post.body, 200)
        : post.data.snippet;
      const tags = post.data.pubDate
        ? undefined
        : post.data.tags;

      return (
        <Card
          title={`#${number}`}
          description={description}
          tags={tags}
          url={post.data.url}
          link={`${post.slug}/`}
          date={post.data.pubDate}
        />
      );
    }))}
  </div>
</section>

<style>
  section {
    display: grid;
    gap: 2rem;
  }
  .grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 600px) {
    .grid {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>