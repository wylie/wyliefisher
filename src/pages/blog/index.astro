---
import Layout from '../../layouts/Layout.astro';
import DataGrid from '../../components/DataGrid.astro';

import { getCollection } from 'astro:content';
import { getPublishedPosts } from '../../lib/blog';

const posts = getPublishedPosts(await getCollection('blog'));
---

<Layout pageTitle="Blog">
	<section class="page-intro">
		<p class="eyebrow">The Ol' Blog</p>
		<h2>Weekly notes from an ordinary, curious life.</h2>
		<p>
			A running Sunday practice: work, family, books, ideas, garden plans, health updates, and whatever
			else seems worth setting down before the week turns over.
		</p>
	</section>
	<DataGrid posts={posts} placeFirstCardRight={true} useNumberTitles={true} />
</Layout>
