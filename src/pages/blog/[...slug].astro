---
import { CollectionEntry, getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: post.slug },
		props: post,
	}));
}
type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content } = await post.render();

// Get all posts to determine index
const allPosts = (await getCollection('blog')).sort(
	(a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf()
);
const number = allPosts.findIndex(p => p.slug === post.slug) !== -1 ? allPosts.length - allPosts.findIndex(p => p.slug === post.slug) : undefined;

---

<Layout pageNumber={number} pubDate={post.data.pubDate} heroImage={post.data.heroImage}>
	<Content />
</Layout>