---
import { CollectionEntry, getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: post.slug },
		props: post,
	}));
}
type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content } = await post.render();

// Get all posts to determine index
const allPosts = (await getCollection('blog')).sort(
	(a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf()
);
const currentIndex = allPosts.findIndex((p) => p.slug === post.slug);
const number = currentIndex !== -1 ? allPosts.length - currentIndex : undefined;

const newerPost = currentIndex > 0 ? allPosts[currentIndex - 1] : undefined;
const olderPost = currentIndex !== -1 && currentIndex < allPosts.length - 1
	? allPosts[currentIndex + 1]
	: undefined;

---


<Layout pageNumber={number} pubDate={post.data.pubDate} heroImage={post.data.heroImage}>
	<nav slot="aboveHero" class="post-nav-row post-nav-row-top" aria-label="Blog post navigation">
		{newerPost ? (
			<a href={`/blog/${newerPost.slug}/`} class="post-nav-link post-nav-left">&larr; newer</a>
		) : (
			<span class="post-nav-spacer" aria-hidden="true"></span>
		)}
		<a href="/blog/" class="post-nav-link post-nav-center">blog index</a>
		{olderPost ? (
			<a href={`/blog/${olderPost.slug}/`} class="post-nav-link post-nav-right">older &rarr;</a>
		) : (
			<span class="post-nav-spacer" aria-hidden="true"></span>
		)}
	</nav>

	<Content />

	<nav class="post-nav-row post-nav-row-bottom" aria-label="Blog post navigation">
		{newerPost ? (
			<a href={`/blog/${newerPost.slug}/`} class="post-nav-link post-nav-left">&larr; newer</a>
		) : (
			<span class="post-nav-spacer" aria-hidden="true"></span>
		)}
		<a href="/blog/" class="post-nav-link post-nav-center">blog index</a>
		{olderPost ? (
			<a href={`/blog/${olderPost.slug}/`} class="post-nav-link post-nav-right">older &rarr;</a>
		) : (
			<span class="post-nav-spacer" aria-hidden="true"></span>
		)}
	</nav>
</Layout>

<style>
	.post-nav-row {
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		align-items: center;
		column-gap: 1rem;
		padding: 0.55rem 0.35rem;
	}

	.post-nav-row-top {
		margin: 0rem 0 1.25rem;
		border-top: 3px dashed var(--border-color);
		border-bottom: 3px dashed var(--border-color);
	}

	.post-nav-row-bottom {
		margin-top: 1.5rem;
		border-top: 3px dashed var(--border-color);
	}

	.post-nav-link {
		display: inline-block;
		text-decoration: none;
		font-weight: bold;
		line-height: 1.2;
	}

	.post-nav-left {
		justify-self: start;
		text-align: left;
	}

	.post-nav-center {
		justify-self: center;
		text-align: center;
	}

	.post-nav-right {
		justify-self: end;
		text-align: right;
	}

	.post-nav-link:hover {
		text-decoration: underline;
	}

	.post-nav-spacer {
		display: inline-block;
		min-width: 4ch;
		min-height: 1em;
	}

	@media (max-width: 480px) {
		.post-nav-row {
			grid-template-columns: 1fr auto 1fr;
			gap: 0.75rem;
			align-items: center;
		}

		.post-nav-left,
		.post-nav-right,
		.post-nav-center {
			font-size: 0.95rem;
		}
	}
</style>