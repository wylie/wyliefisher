---
import { CollectionEntry, getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import DetailNav from '../../components/DetailNav.astro';
import { getPublishedPosts } from '../../lib/blog';

export async function getStaticPaths() {
	const posts = getPublishedPosts(await getCollection('blog'));
	return posts.map((post) => ({
		params: { slug: post.slug },
		props: post,
	}));
}
type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content } = await post.render();

// Get all posts to determine index
const allPosts = getPublishedPosts(await getCollection('blog'));
const currentIndex = allPosts.findIndex((p) => p.slug === post.slug);
const number = currentIndex !== -1 ? allPosts.length - currentIndex : undefined;

const newerPost = currentIndex > 0 ? allPosts[currentIndex - 1] : undefined;
const olderPost = currentIndex !== -1 && currentIndex < allPosts.length - 1
	? allPosts[currentIndex + 1]
	: undefined;

---


<Layout pageNumber={number} pubDate={post.data.pubDate} heroImage={post.data.heroImage}>
	<DetailNav
		slot="aboveHero"
		newer={newerPost && { href: `/blog/${newerPost.slug}/` }}
		older={olderPost && { href: `/blog/${olderPost.slug}/` }}
		indexHref="/blog/"
		indexLabel="Blog index"
		ariaLabel="Blog post navigation"
	/>

	<Content />

	<DetailNav
		newer={newerPost && { href: `/blog/${newerPost.slug}/` }}
		older={olderPost && { href: `/blog/${olderPost.slug}/` }}
		indexHref="/blog/"
		indexLabel="Blog index"
		position="bottom"
		ariaLabel="Blog post navigation"
	/>
</Layout>
