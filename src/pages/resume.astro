---
import Layout from '../layouts/Layout.astro';
---
<Layout pageTitle="Resume">
	<section class="resume-hero">
		<div class="summary">
			<p class="eyebrow">Resume</p>
			<h2>Operations-minded leadership with a builder’s eye for systems, clarity, and practical execution.</h2>
			<p class="summary-copy">
				Experienced professional with a strong background in problem-solving, collaboration, and
				building effective systems. Known for clear communication, reliability, and a thoughtful
				approach to both technical and day-to-day work.
			</p>
		</div>
		<aside class="downloads" aria-label="Resume downloads">
			<h3>Download</h3>
			<div class="download-grid">
				<a href="/resume/Wylie_Fisher_resume.pdf" download data-track-download="pdf" class="download-item">
					<span class="download-format">PDF</span>
					<span>Portable document</span>
				</a>
				<a href="/resume/Wylie_Fisher_resume.docx" download data-track-download="docx" class="download-item">
					<span class="download-format">Word</span>
					<span>Editable document</span>
				</a>
			</div>
		</aside>
	</section>

	<section class="resume-section">
		<h2>Skills</h2>
		<div class="section-stack skills-grid">
			<div class="panel">
				<h3>Leadership, Operations &amp; Strategy</h3>
				<p>
					Operations Management, Team Leadership, Hiring &amp; Onboarding, Staff Training &amp; Mentorship,
					Scheduling &amp; Payroll Oversight, Budgeting &amp; Forecasting, Contribution Margin Analysis,
					Scenario Planning, Program Development, Vendor Management, Risk Management, Incident Response,
					Clear Communication, Change Management
				</p>
			</div>
			<div class="panel">
				<h3>Systems &amp; Process</h3>
				<p>
					Operational Systems Design, Process Documentation, Cross-Department Coordination,
					Data-Informed Decision Making, Tool Evaluation &amp; Implementation, Workflow Optimization,
					Google Sheets (advanced formulas), Reporting &amp; Analysis
				</p>
			</div>
			<div class="panel">
				<h3>Technical Foundations</h3>
				<p>
					HTML, CSS, JavaScript, WordPress, Basic PHP &amp; Python, Accessibility Awareness (WCAG),
					Documentation, Version Control (Git)
				</p>
			</div>
		</div>
	</section>

	<section class="resume-section">
		<h2>Work Experience</h2>
		<div class="experience-list">
			<article class="experience-item">
				<div class="experience-heading">
					<div>
						<h3>Fiddlehead Farm &amp; Forest | Fletcher, NC</h3>
						<p class="role-description">
							Fiddlehead Farm &amp; Forest is a community-focused climbing gym, bike park, and fitness
							facility offering youth programs, events, and year-round recreation.
						</p>
						<h4>General Manager</h4>
					</div>
					<p class="dates">03/2025 - 03/2026</p>
				</div>
				<ul>
					<li>Led day-to-day operations across all departments, ensuring safe, consistent, and high-quality experiences.</li>
					<li>Built and refined systems for scheduling, payroll, budgeting, and documentation.</li>
					<li>Managed financial planning, contribution analysis, and scenario modeling.</li>
					<li>Oversaw hiring, onboarding, training, and performance management across multiple roles.</li>
					<li>Partnered with program leads to design, launch, and iterate youth programs and camps.</li>
					<li>Coordinated facility operations, risk management, and incident response.</li>
					<li>Collaborated with ownership, vendors, and community partners on events and long-term planning.</li>
				</ul>
			</article>

			<article class="experience-item">
				<div class="experience-heading">
					<div>
						<h3 class="company">EBSCO Information Services | Ipswich, MA</h3>
						<p class="role-description">
							EBSCO Information Services is a leader in research databases and discovery services,
							supporting libraries, academic institutions, and healthcare providers.
						</p>
						<h4>Principal Software Engineer</h4>
					</div>
					<p class="dates">10/2010 - 09/2024</p>
				</div>
				<ul>
					<li>Led the design and long-term maintenance of a reusable front-end component library.</li>
					<li>Established documentation standards and authored comprehensive technical guides.</li>
					<li>Partnered with designers, product managers, and backend teams to align solutions with user and business goals.</li>
					<li>Mentored engineers in accessibility, responsive design, and maintainable front-end practices.</li>
				</ul>
				<div class="experience-heading experience-heading-secondary">
					<div>
						<h4>Senior / Web User Interface Engineer</h4>
					</div>
				</div>
				<ul>
					<li>Improved application performance and maintainability through frontend architecture work.</li>
					<li>Conducted code reviews and collaborated closely with designers and engineers on accessible features.</li>
					<li>Supported ongoing feature development while maintaining high quality and stability standards.</li>
				</ul>
			</article>

			<article class="experience-item">
				<div class="experience-heading">
					<div>
						<h3 class="company">Wayfair | Boston, MA</h3>
						<p class="role-description">
							Wayfair is a leading online retailer in home furnishings and decor, offering an extensive
							product selection across multiple brands globally.
						</p>
						<h4>Front End Engineer II</h4>
					</div>
					<p class="dates">04/2016 - 10/2016</p>
				</div>
				<ul>
					<li>Delivered scalable, maintainable features for five e-commerce platforms using PHP, JavaScript, HTML, and CSS.</li>
					<li>Enhanced site performance and reliability by implementing front-end best practices.</li>
				</ul>
			</article>

			<article class="experience-item">
				<div class="experience-heading">
					<div>
						<h3 class="company">Freelance | Hendersonville, NC</h3>
						<p class="role-description">
							Provided freelance web development services for a wide range of clients, building custom
							websites and tailored digital solutions to meet specific needs.
						</p>
						<h4>Freelance Web Developer</h4>
					</div>
					<p class="dates">12/2009 - 12/2025</p>
				</div>
				<ul>
					<li>Built and maintained custom websites with a focus on scalable, responsive designs.</li>
					<li>Delivered tailored WordPress themes and hand-coded websites integrating CMS and database management.</li>
				</ul>
			</article>

			<article class="experience-item compact">
				<div class="experience-heading">
					<div>
						<h3 class="company">The Biltmore Company | Asheville, NC</h3>
						<p class="role-description">
							Supported website updates and content publishing within the marketing department,
							collaborating with internal teams to ensure accurate and timely delivery of web content.
						</p>
						<h4>Web Developer</h4>
					</div>
					<p class="dates">11/2005 - 12/2009</p>
				</div>
			</article>

			<article class="experience-item compact">
				<div class="experience-heading">
					<div>
						<h3 class="company">Arnold Worldwide | Boston, MA</h3>
						<p class="role-description">
							Worked within a fast-paced marketing agency environment, contributing to updates and
							maintenance for major brand websites while collaborating closely with designers.
						</p>
						<h4>Web Developer</h4>
					</div>
					<p class="dates">3/2001 - 6/2002</p>
				</div>
			</article>

			<article class="experience-item compact">
				<div class="experience-heading">
					<div>
						<h3 class="company">Mirror Image | Cambridge, MA</h3>
						<p class="role-description">
							Produced high-quality screen-printed apparel for well-known brands and organizations,
							contributing to award-winning designs through attention to detail and craftsmanship.
						</p>
						<h4>Screenprinter</h4>
					</div>
					<p class="dates">10/1994 - 2/2001</p>
				</div>
			</article>
		</div>
	</section>

	<script>
		document.addEventListener('astro:page-load', () => {
			document.querySelectorAll('[data-track-download]').forEach((link) => {
				link.addEventListener('click', (e) => {
					const format = (e.currentTarget as HTMLElement).getAttribute('data-track-download');
					const w = window as any;
					if (typeof w.gtag !== 'undefined') {
						w.gtag('event', 'file_download', {
							file_name: `Wylie_Fisher_resume.${format}`,
							file_extension: format,
							link_url: (e.currentTarget as HTMLAnchorElement).href
						});
					}
				});
			});
		});
	</script>
</Layout>

<style>
	.resume-hero {
		display: grid;
		gap: 1.5rem;
	}

	.summary {
		max-width: 44rem;
	}

	.summary-copy {
		margin-top: 1rem;
		color: var(--color-text-soft);
	}

	.downloads,
	.panel,
	.experience-item {
		border: 1px solid var(--color-line);
		border-radius: var(--radius-md);
		background: color-mix(in srgb, var(--color-panel) 88%, white 12%);
	}

	.downloads {
		padding: 1.25rem;
		height: fit-content;
	}

	.download-grid {
		display: grid;
		gap: 0.85rem;
		margin-top: 1rem;
	}

	.download-item {
		display: grid;
		gap: 0.15rem;
		padding: 1rem;
		border: 1px solid var(--color-line);
		border-radius: 1rem;
		text-decoration: none;
		color: inherit;
	}

	.download-format {
		font-family: var(--font-sans);
		font-size: 0.92rem;
		font-weight: 700;
	}

	.resume-section h2 {
		padding-bottom: 0.75rem;
		border-bottom: 1px solid var(--color-line);
	}

	.section-stack,
	.experience-list {
		display: grid;
		gap: 1rem;
		margin-top: 1rem;
	}

	.panel,
	.experience-item {
		padding: 1.25rem;
	}

	.experience-item.compact {
		padding-bottom: 1rem;
	}

	.experience-heading {
		display: grid;
		gap: 0.65rem;
		margin-bottom: 0.85rem;
	}

	.experience-heading-secondary {
		margin-top: 1.5rem;
	}

	.role-description,
	.dates {
		font-size: 1rem;
		color: var(--color-text-soft);
	}

	.dates {
		font-family: var(--font-sans);
		font-weight: 700;
	}

	.experience-item ul {
		display: grid;
		gap: 0.6rem;
	}

	@media (min-width: 900px) {
		.resume-hero {
			grid-template-columns: minmax(0, 1fr) 18rem;
			align-items: start;
		}

		.skills-grid {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}

		.experience-heading {
			grid-template-columns: minmax(0, 1fr) auto;
			align-items: start;
		}
	}
</style>
