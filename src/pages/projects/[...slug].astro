---
import { CollectionEntry, getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import DetailNav from '../../components/DetailNav.astro';
import Tags from '../../components/Tags.astro';

export async function getStaticPaths() {
	const projects = await getCollection('project');
	return projects.map((post) => ({
		params: { slug: post.slug },
		props: post,
	}));
}
type Props = CollectionEntry<'project'>;

const post = Astro.props;
const { Content } = await post.render();

const allProjects = (await getCollection('project')).sort(
	(a, b) => (a.data.order ?? Number.MAX_SAFE_INTEGER) - (b.data.order ?? Number.MAX_SAFE_INTEGER)
);
const currentIndex = allProjects.findIndex((project) => project.slug === post.slug);
const newerProject = currentIndex > 0 ? allProjects[currentIndex - 1] : undefined;
const olderProject = currentIndex !== -1 && currentIndex < allProjects.length - 1
	? allProjects[currentIndex + 1]
	: undefined;
---

<Layout pageTitle={post.data.title} {...post.data}>
	<section class="project-hero">
		<p class="eyebrow">Project</p>
		<h2>{post.data.title}</h2>
		<p>{post.data.snippet}</p>
		<div class="project-meta">
			{post.data.url && (
				<a href={post.data.url} target="_blank" rel="noopener noreferrer" class="project-link">
					Visit site <span aria-hidden="true">&rarr;</span>
				</a>
			)}
			<Tags tags={post.data.tags} compact={true} />
		</div>
	</section>

	<DetailNav
		slot="aboveHero"
		newer={newerProject && { href: `/projects/${newerProject.slug}/` }}
		older={olderProject && { href: `/projects/${olderProject.slug}/` }}
		indexHref="/projects/"
		indexLabel="Project index"
		ariaLabel="Project navigation"
	/>

	<Content />

	<DetailNav
		newer={newerProject && { href: `/projects/${newerProject.slug}/` }}
		older={olderProject && { href: `/projects/${olderProject.slug}/` }}
		indexHref="/projects/"
		indexLabel="Project index"
		position="bottom"
		ariaLabel="Project navigation"
	/>
</Layout>

<style>
	.project-hero {
		max-width: 48rem;
		gap: 0.85rem;
	}

	.project-hero > p:last-of-type {
		color: var(--color-text-soft);
	}

	.project-meta {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem 1rem;
		align-items: center;
	}

	.project-link {
		display: inline-flex;
		align-items: center;
		width: fit-content;
		padding: 0.65rem 1rem;
		border-radius: 999px;
		background: var(--color-text);
		color: var(--color-panel);
		font-family: var(--font-sans);
		font-size: 0.92rem;
		font-weight: 700;
		text-decoration: none;
	}
</style>
