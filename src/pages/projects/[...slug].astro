---
import { CollectionEntry, getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
	const projects = await getCollection('project');
	return projects.map((post) => ({
		params: { slug: post.slug },
		props: post,
	}));
}
type Props = CollectionEntry<'project'>;

const post = Astro.props;
const { Content } = await post.render();

const allProjects = (await getCollection('project')).sort(
	(a, b) => (a.data.order ?? Number.MAX_SAFE_INTEGER) - (b.data.order ?? Number.MAX_SAFE_INTEGER)
);
const currentIndex = allProjects.findIndex((project) => project.slug === post.slug);
const newerProject = currentIndex > 0 ? allProjects[currentIndex - 1] : undefined;
const olderProject = currentIndex !== -1 && currentIndex < allProjects.length - 1
	? allProjects[currentIndex + 1]
	: undefined;
---

<Layout pageTitle={post.data.title} {...post.data}>
	<nav slot="aboveHero" class="post-nav-row post-nav-row-top" aria-label="Project navigation">
		{newerProject ? (
			<a href={`/projects/${newerProject.slug}/`} class="post-nav-link post-nav-left">&larr; newer</a>
		) : (
			<span class="post-nav-spacer" aria-hidden="true"></span>
		)}
		<a href="/projects/" class="post-nav-link post-nav-center">project index</a>
		{olderProject ? (
			<a href={`/projects/${olderProject.slug}/`} class="post-nav-link post-nav-right">older &rarr;</a>
		) : (
			<span class="post-nav-spacer" aria-hidden="true"></span>
		)}
	</nav>

	<Content />

	<nav class="post-nav-row post-nav-row-bottom" aria-label="Project navigation">
		{newerProject ? (
			<a href={`/projects/${newerProject.slug}/`} class="post-nav-link post-nav-left">&larr; newer</a>
		) : (
			<span class="post-nav-spacer" aria-hidden="true"></span>
		)}
		<a href="/projects/" class="post-nav-link post-nav-center">project index</a>
		{olderProject ? (
			<a href={`/projects/${olderProject.slug}/`} class="post-nav-link post-nav-right">older &rarr;</a>
		) : (
			<span class="post-nav-spacer" aria-hidden="true"></span>
		)}
	</nav>
</Layout>

<style>
	.post-nav-row {
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		align-items: center;
		column-gap: 1rem;
		padding: 0.55rem 0.35rem;
	}

	.post-nav-row-top {
		margin: 0rem 0 1.25rem;
		border-top: 3px dashed var(--border-color);
		border-bottom: 3px dashed var(--border-color);
	}

	.post-nav-row-bottom {
		margin-top: 1.5rem;
		border-top: 3px dashed var(--border-color);
	}

	.post-nav-link {
		display: inline-block;
		text-decoration: none;
		font-weight: bold;
		line-height: 1.2;
	}

	.post-nav-left {
		justify-self: start;
		text-align: left;
	}

	.post-nav-center {
		justify-self: center;
		text-align: center;
	}

	.post-nav-right {
		justify-self: end;
		text-align: right;
	}

	.post-nav-link:hover {
		text-decoration: underline;
	}

	.post-nav-spacer {
		display: inline-block;
		min-width: 4ch;
		min-height: 1em;
	}

	@media (max-width: 480px) {
		.post-nav-row {
			grid-template-columns: 1fr auto 1fr;
			gap: 0.75rem;
			align-items: center;
		}

		.post-nav-left,
		.post-nav-right,
		.post-nav-center {
			font-size: 0.95rem;
		}
	}
</style>
